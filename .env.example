# ===============================================
# Greet — Environment Variables
# Deliver to DevOps for staging/production setup
# ===============================================

# ── Core (REQUIRED) ──
NODE_ENV=
PORT=
DATABASE_URL=
SESSION_SECRET=
CREDENTIAL_ENCRYPTION_KEY=

# ── Authentication — Twilio (SMS OTP) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ── Authentication — Email (OTP + Notifications) ──
SENDGRID_API_KEY=
EMAIL_FROM=noreply@certain.com

# ── AI Features — Anthropic Claude ──
ANTHROPIC_API_KEY=

# ── Printing ──
PRINTNODE_API_KEY=

# ── AWS S3 (Object Storage) ──
AWS_REGION=us-west-2
S3_BUCKET_NAME=
S3_OBJECT_PREFIX=uploads/

# ── Slack Webhooks ──
SLACK_FEEDBACK_WEBHOOK_URL=
SLACK_USAGE_WEBHOOK_URL=

# ── Feature Flags ──
PEN_TEST_MODE=false

# ── Optional Overrides ──
# LOG_LEVEL=info
# DISABLE_HTTPS_UPGRADE=false
# RUN_MIGRATIONS=true
